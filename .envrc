# direnv auto-loads this on `cd` into the repo root.
#
# First time after cloning: run `direnv allow .` to approve.
#
# What gets set up:
#
#   1. ESP-IDF environment — exposes idf.py, esptool, the riscv toolchain.
#      No more needing to run the `idf` alias to enter a build session.
#
#   2. A Python dev venv with homeassistant + the bridge package installed
#      editable. IDEs (VS Code, PyCharm) pick it up automatically via the
#      .venv/ path and resolve homeassistant.* + panel_bridge.* imports
#      properly, giving you working autocomplete in custom_components/
#      thread_panel/ and platform/bridge/. First-run pip install pulls
#      ~500 MB of HA dependencies, takes a few minutes, happens once.
#
#      The venv is activated in the shell too. idf.py self-relaunches under
#      IDF's python via $IDF_PYTHON_ENV_PATH, so ESP-IDF tools still work
#      with our venv active.
#
#   3. tools/ on PATH so `panel-ota` (and future scripts) are runnable
#      from any subdirectory of the repo.

# 1. ESP-IDF env
if [[ -f "$HOME/.espressif/v6.0/esp-idf/export.sh" ]]; then
    source "$HOME/.espressif/v6.0/esp-idf/export.sh" >/dev/null 2>&1
else
    echo "panel-dev: ESP-IDF export.sh not found at $HOME/.espressif/v6.0/esp-idf — skipping IDF activation" >&2
fi

# 2. Dev venv for HA + bridge intellisense
if [[ ! -d .venv ]]; then
    echo "panel-dev: creating .venv with homeassistant + bridge (one-time, ~2-5 min)..."
    python3 -m venv .venv
    .venv/bin/pip install --upgrade pip --quiet
    .venv/bin/pip install homeassistant voluptuous --quiet
    .venv/bin/pip install -e platform/bridge --quiet
    echo "panel-dev: .venv ready."
fi
source .venv/bin/activate

# 3. Repo scripts on PATH
PATH_add tools
