# direnv auto-loads this on `cd` into the repo root.
#
# First time after cloning: run `direnv allow .` to approve.
#
# What gets set up:
#
#   1. A Python dev venv with homeassistant + the bridge package installed
#      editable. IDEs (VS Code, PyCharm) pick it up automatically via the
#      .venv/ path and resolve homeassistant.* + panel_bridge.* imports
#      properly, giving you working autocomplete in custom_components/
#      thread_panel/ and platform/bridge/. First-run pip install pulls
#      ~500 MB of HA dependencies, takes a few minutes, happens once.
#
#   2. tools/ on PATH so `panel-ota` (and future scripts) are runnable
#      from any subdirectory of the repo.
#
# ESP-IDF is NOT auto-loaded — run your `idf` alias to enter a build
# session. The reason: IDF's export.sh resolves its Python venv via
# whatever `python3` points to at the time, and direnv's subshell picks
# a different Python than your interactive shell, so sourcing it under
# direnv fails with a "venv not found" error. Letting `idf` run from
# your interactive zsh keeps Python resolution stable and sidesteps it.

# 1. Dev venv for HA + bridge intellisense
if [[ ! -d .venv ]]; then
    echo "panel-dev: creating .venv with homeassistant + bridge (one-time, ~2-5 min)..."
    python3 -m venv .venv
    .venv/bin/pip install --upgrade pip --quiet
    .venv/bin/pip install homeassistant voluptuous --quiet
    .venv/bin/pip install -e platform/bridge --quiet
    echo "panel-dev: .venv ready."
fi
source .venv/bin/activate

# 2. Repo scripts on PATH
PATH_add tools
