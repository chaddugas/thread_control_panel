# ESP-IDF build artifacts
build/
managed_components/
sdkconfig.old
dependencies.lock

# sdkconfig contains plaintext MQTT credentials per build_plan.md.
# Each panel firmware tree generates its own; never commit them.
sdkconfig

# Node / Vite
node_modules/
dist/
.vite/
*.local

# Per-panel UI builds are committed for kiosk deploy. `cut-release` rebuilds
# dist/ before tagging so each release ships a matching source + bundle, and
# the Pi pulls a ready-to-serve dist/ on each panel-bridge restart instead of
# building locally.
!panels/*/ui/dist/
!panels/*/ui/dist/**

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# direnv cache
.direnv/

# Playwright MCP artifacts (Claude-driven browser sessions during dev;
# screenshots, snapshots, and console logs — never commit)
.playwright-mcp/

# OS / editor
.DS_Store
.idea/
*.swp
*.swo
*~

# Local-only IDE settings (the IDE-shared ones are committed under .vscode/)
.vscode/*.local
.vscode/launch.json

# Local commit-message scratch file (Claude populates with draft messages
# after finishing a chunk of work; user reviews/edits before committing).
# Set `git config commit.template <repo-path>/.gitmessage.txt` to use.
.gitmessage.txt
