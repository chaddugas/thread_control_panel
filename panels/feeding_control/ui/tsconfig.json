{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@thread-panel/ui-core": ["../../../platform/ui-core/src"],
      "@thread-panel/ui-core/*": ["../../../platform/ui-core/src/*"],
      "vue": ["./node_modules/vue"],
      "pinia": ["./node_modules/pinia"]
    },
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src/**/*", "src/**/*.vue"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
