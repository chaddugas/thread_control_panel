#!/usr/bin/env python3
"""panel-ota — flash the C6 over Thread via HTTP OTA.

Run this from the firmware directory after `idf.py build`. It:
  1. Finds the Mac's LAN IP (kernel-route trick, no static IP needed).
  2. Starts a local HTTP server serving the built firmware binary.
  3. Publishes `cmd/ota` with the URL to the panel's MQTT broker.
  4. Watches the `availability` topic for the C6's reboot and return to online.
  5. Shuts down the HTTP server.

Configuration via env vars (set in ~/.zshrc or similar):

    PANEL_MQTT_BROKER   broker hostname or IP            required
    PANEL_MQTT_PORT     broker port                      default 8883
    PANEL_MQTT_CAFILE   path to CA cert (ISRG Root X1)   required
    PANEL_MQTT_USER     username                         default mqtt_user
    PANEL_MQTT_PASSWORD password                         required
    PANEL_MQTT_INSECURE "1" to skip TLS hostname verify  default unset
    PANEL_ID            panel id                         default feeding_control
    PANEL_NAT64_PREFIX  OTBR's NAT64 /96 prefix          default 64:ff9b::
                        Find it on the C6 via ot_cli
                        `netdata show` under Routes —
                        look for a /96 route.
"""

from __future__ import annotations

import argparse
import ipaddress
import json
import os
import socket
import subprocess
import sys
import threading
import time
from http.server import HTTPServer, SimpleHTTPRequestHandler
from pathlib import Path


def local_ip() -> str:
    """Mac's LAN IP via 'what route would reach 8.8.8.8'."""
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        s.connect(("8.8.8.8", 80))
        return s.getsockname()[0]
    finally:
        s.close()


def nat64(ipv4: str, prefix: str) -> str:
    """Synthesize an IPv6 address from an IPv4 using a NAT64 /96 prefix.

    OTBR routes its NAT64 prefix through itself when NAT64 is enabled,
    translating to the real IPv4 destination on the LAN side. The C6 is
    IPv6-only (no IPv4 lwIP stack), so it reaches LAN IPv4 hosts
    exclusively through this prefix.

    The prefix isn't universal — the well-known `64:ff9b::` is common but
    many OTBR builds derive a mesh-local prefix like
    `fd64:cc6b:b1f6:2::`. Pass whatever OTBR actually advertises (see
    `ot_cli netdata show` on any Thread device).
    """
    # ipaddress.IPv6Network handles any valid /96 form (:: or full).
    net = ipaddress.IPv6Network(f"{prefix.rstrip(':')}::/96", strict=False)
    base = int(net.network_address)
    ip4 = int(ipaddress.IPv4Address(ipv4))
    return str(ipaddress.IPv6Address(base | ip4))


def serve(directory: str, port: int) -> HTTPServer:
    """Start a background HTTP server serving `directory`. Logs concisely."""

    class Handler(SimpleHTTPRequestHandler):
        def __init__(self, *a, **kw):
            super().__init__(*a, directory=directory, **kw)

        def log_message(self, fmt, *args):
            print(f"  http: {self.address_string()} — {fmt % args}")

    server = HTTPServer(("0.0.0.0", port), Handler)
    threading.Thread(target=server.serve_forever, daemon=True).start()
    return server


def mqtt_flags(args: argparse.Namespace) -> list[str]:
    flags = ["-h", args.broker, "-p", str(args.broker_port), "--cafile", args.cafile]
    if args.insecure:
        flags.append("--insecure")
    if args.user:
        flags += ["-u", args.user]
    if args.password:
        flags += ["-P", args.password]
    return flags


def publish_ota(args: argparse.Namespace, url: str) -> None:
    topic = f"thread_panel/{args.panel_id}/cmd/ota"
    # Compact separators (no spaces) match the rest of the project's MQTT
    # payloads and the C6's strstr-based parser.
    payload = json.dumps({"url": url}, separators=(",", ":"))
    subprocess.run(
        ["mosquitto_pub", *mqtt_flags(args), "-t", topic, "-m", payload],
        check=True,
    )
    print(f"Published {payload} to {topic}")


def wait_for_reboot(args: argparse.Namespace, timeout: int) -> bool:
    """Watch availability topic for an offline→online transition.

    Clean C6 reboot via esp_restart() doesn't send a graceful MQTT DISCONNECT,
    so the broker detects the drop via keepalive (~60s) before publishing LWT
    "offline". Give a generous timeout.
    """
    topic = f"thread_panel/{args.panel_id}/availability"
    proc = subprocess.Popen(
        ["mosquitto_sub", *mqtt_flags(args), "-t", topic],
        stdout=subprocess.PIPE,
        text=True,
        bufsize=1,
    )

    # Timer thread terminates the subprocess if the deadline passes with no
    # trigger — readline() would otherwise block forever.
    def kill_after():
        time.sleep(timeout)
        if proc.poll() is None:
            proc.terminate()

    threading.Thread(target=kill_after, daemon=True).start()

    seen_offline = False
    try:
        for line in proc.stdout:  # type: ignore[union-attr]
            state = line.strip()
            print(f"  availability: {state}")
            if state == "offline":
                seen_offline = True
            elif state == "online" and seen_offline:
                return True
        return False
    finally:
        if proc.poll() is None:
            proc.terminate()
            try:
                proc.wait(timeout=2)
            except subprocess.TimeoutExpired:
                proc.kill()


def find_firmware() -> Path | None:
    build = Path.cwd() / "build"
    if not build.is_dir():
        return None
    # Preferred: read ESP-IDF's own project metadata for the canonical name.
    desc = build / "project_description.json"
    if desc.is_file():
        try:
            with open(desc) as f:
                data = json.load(f)
            name = data.get("project_name")
            if name:
                fw = build / f"{name}.bin"
                if fw.is_file():
                    return fw
        except (OSError, json.JSONDecodeError):
            pass
    # Fallback: glob, excluding the auxiliary bins that ESP-IDF generates
    # alongside the app bin (bootloader and partition-table live in subdirs
    # so they're already excluded by the top-level glob; ota_data_initial
    # appears once OTA is configured).
    AUX = {"ota_data_initial.bin", "bootloader.bin", "partition-table.bin"}
    candidates = [p for p in build.glob("*.bin") if p.name not in AUX]
    return candidates[0] if len(candidates) == 1 else None


def main() -> int:
    p = argparse.ArgumentParser(
        description="Flash the C6 via HTTP OTA.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument("--panel-id", default=os.environ.get("PANEL_ID", "feeding_control"))
    p.add_argument("--broker", default=os.environ.get("PANEL_MQTT_BROKER"))
    p.add_argument(
        "--broker-port",
        type=int,
        default=int(os.environ.get("PANEL_MQTT_PORT", "8883")),
    )
    p.add_argument("--cafile", default=os.environ.get("PANEL_MQTT_CAFILE"))
    p.add_argument("--user", default=os.environ.get("PANEL_MQTT_USER", "mqtt_user"))
    p.add_argument("--password", default=os.environ.get("PANEL_MQTT_PASSWORD"))
    p.add_argument(
        "--insecure",
        action="store_true",
        default=bool(os.environ.get("PANEL_MQTT_INSECURE")),
    )
    p.add_argument(
        "--nat64-prefix",
        default=os.environ.get("PANEL_NAT64_PREFIX", "64:ff9b::"),
        help=(
            "OTBR's NAT64 /96 prefix. Default 64:ff9b::. "
            "Find yours via `ot_cli netdata show` (Routes section)."
        ),
    )
    p.add_argument(
        "--firmware",
        type=Path,
        help="Path to firmware .bin (default: ./build/<project>.bin)",
    )
    p.add_argument("--http-port", type=int, default=8000)
    p.add_argument(
        "--timeout",
        type=int,
        default=900,
        help="Seconds to wait for C6 reboot round trip",
    )
    p.add_argument(
        "--no-wait",
        action="store_true",
        help="Publish and exit, don't watch for reboot",
    )
    args = p.parse_args()

    errors = []
    if not args.broker:
        errors.append("--broker or PANEL_MQTT_BROKER required")
    if not args.cafile:
        errors.append("--cafile or PANEL_MQTT_CAFILE required")
    if not args.password:
        errors.append("--password or PANEL_MQTT_PASSWORD required")
    if errors:
        for e in errors:
            print(f"panel-ota: {e}", file=sys.stderr)
        return 2

    fw = args.firmware or find_firmware()
    if fw is None:
        print(
            "panel-ota: couldn't locate firmware. Run from the firmware/ dir "
            "after `idf.py build`, or pass --firmware PATH.",
            file=sys.stderr,
        )
        return 2
    if not fw.is_file():
        print(f"panel-ota: firmware not found at {fw}", file=sys.stderr)
        return 2

    ip = local_ip()
    try:
        nat64_ip = nat64(ip, args.nat64_prefix)
    except ValueError as e:
        print(
            f"panel-ota: invalid --nat64-prefix {args.nat64_prefix!r}: {e}",
            file=sys.stderr,
        )
        return 2
    print(f"Local IPv4:   {ip}")
    print(f"NAT64 IPv6:   [{nat64_ip}] (prefix {args.nat64_prefix})")
    print(f"Firmware:     {fw} ({fw.stat().st_size} bytes)")

    server = serve(str(fw.parent), args.http_port)
    # C6 reaches the Mac via NAT64 (Thread → OTBR → LAN IPv4). Mac's
    # HTTP server is listening on IPv4; OTBR does the translation.
    url = f"http://[{nat64_ip}]:{args.http_port}/{fw.name}"
    print(f"Publishing url: {url}")

    try:
        publish_ota(args, url)
        if args.no_wait:
            print("Published. Exiting without waiting (--no-wait).")
            return 0

        print(f"Waiting up to {args.timeout}s for C6 reboot...")
        if wait_for_reboot(args, args.timeout):
            print("✓ OTA complete — C6 rebooted and reconnected.")
            return 0
        print(
            "✗ Timed out without seeing offline→online. "
            "Check C6 monitor / HA availability / journalctl.",
            file=sys.stderr,
        )
        return 1
    finally:
        server.shutdown()


if __name__ == "__main__":
    sys.exit(main())
